# ========== Cloudflare Tunnel 生产部署 ==========
# DEBUG=0 时务必设置 SECRET_KEY、ALLOWED_HOSTS、CSRF_TRUSTED_ORIGINS
DEBUG=0
SECRET_KEY=请替换为随机长字符串
ALLOWED_HOSTS=app.你的域名.com
CSRF_TRUSTED_ORIGINS=https://app.你的域名.com

# 主 API：智谱（免费视觉模型）
WECHAT_IMPORT_VISION_API_KEY=
WECHAT_IMPORT_VISION_API_BASE=https://open.bigmodel.cn/api/paas/v4
WECHAT_IMPORT_VISION_MODEL=glm-4.6v-flash
WECHAT_IMPORT_VISION_JSON_MODE=1

# 备用 1：硅基流动（推荐，注册送额度，国内直连）
# 注册：https://cloud.siliconflow.cn
WECHAT_IMPORT_VISION_BACKUP_1_API_KEY=
WECHAT_IMPORT_VISION_BACKUP_1_API_BASE=https://api.siliconflow.cn/v1
WECHAT_IMPORT_VISION_BACKUP_1_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct
WECHAT_IMPORT_VISION_BACKUP_1_JSON_MODE=0

# 备用 2：阿里云百炼（非永久免费，新用户约 100 万 Token 免费额度/90 天，用完按量计费）
# 注册/API Key：https://bailian.console.aliyun.com
# 建议在控制台开启「免费额度用完即停」
WECHAT_IMPORT_VISION_BACKUP_2_API_KEY=
WECHAT_IMPORT_VISION_BACKUP_2_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
WECHAT_IMPORT_VISION_BACKUP_2_MODEL=qwen-vl-plus
WECHAT_IMPORT_VISION_BACKUP_2_JSON_MODE=0
